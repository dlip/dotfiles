#!/usr/bin/env bash
set -euo pipefail

# Herdr project workspace manager (herdr port of `t`).
# Picks a project under $PROJECTS with fzf and opens a Herdr workspace for it,
# with one tab each for editor, shell, git (lazygit), and files (yazi).

PROJECTS="$HOME/code"
CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/h-projects"
PLUGINS_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/herdr/plugins"

# Herdr rewrites plugin paths to absolute and expands neither ~ nor $HOME, so
# the generated plugins.json is machine-specific and isn't tracked in the repo.
# The plugin *sources* are tracked, so (re)link them here with absolute paths.
# Linking is local, idempotent, and takes effect on the live server.
link_plugins() {
  local dir
  for dir in "$PLUGINS_DIR"/*/; do
    [ -f "$dir/herdr-plugin.toml" ] || continue
    herdr plugin link "${dir%/}" >/dev/null 2>&1 || true
  done
}

# The program each named tab should run. The shell tab stays a bare shell.
tab_program() {
  case "$1" in
    editor) echo "${EDITOR:-vi}" ;;
    git) echo lazygit ;;
    files) echo yazi ;;
    *) echo "" ;;
  esac
}

# Re-launch each tab's program in every pane of a workspace. Used after a Herdr
# server restart, where every restored pane has dropped back to a bare shell, so
# running unconditionally is safe (no live program to clobber).
repopulate_workspace() {
  local ws="$1" tab_id pane_id label cmd
  while read -r tab_id pane_id; do
    label=$(herdr tab get "$tab_id" | jq -r '.result.tab.label')
    cmd=$(tab_program "$label")
    [ -n "$cmd" ] && herdr pane run "$pane_id" "$cmd" >/dev/null
  done < <(herdr pane list --workspace "$ws" \
    | jq -r '.result.panes[] | "\(.tab_id) \(.pane_id)"')
}

# --restore: repopulate every workspace. Run in the background at Herdr startup
# so restored workspaces get their editor/git/files programs back automatically.
if [ "${1:-}" = "--restore" ]; then
  # Wait for the freshly started server's socket (background, so no visible lag).
  for _ in $(seq 1 100); do
    [ "$(herdr status server 2>/dev/null | awk '/^status:/{print $2}')" = "running" ] && break
    sleep 0.2
  done
  # Give restored pane shells a moment to finish initializing so early
  # keystrokes aren't dropped.
  sleep 1
  link_plugins
  herdr workspace list 2>/dev/null | jq -r '.result.workspaces[].workspace_id' \
    | while read -r ws; do repopulate_workspace "$ws"; done
  exit 0
fi

# The workspace/tab/pane commands need a running Herdr server. When run from a
# plain shell we launch Herdr and attach. If no server is running yet, this is a
# cold start that will restore saved workspaces as bare shells, so kick off a
# background restore to re-launch their programs. If a server is already
# running, just attach — restoring would type into live programs.
if [ -z "${HERDR_PANE_ID:-}" ]; then
  if [ "$(herdr status server 2>/dev/null | awk '/^status:/{print $2}')" != "running" ]; then
    ("$0" --restore >/dev/null 2>&1 &)
  fi
  exec herdr
fi

# Building the project list (find + per-dir zoxide sync + frecency query) is
# slow, so cache the candidate list and only rebuild it once a day. Force a
# rebuild with `h --refresh`.
refresh=0
if [ "${1:-}" = "--refresh" ]; then
  refresh=1
  shift
fi

cache_stale=1
if [ "$refresh" -eq 0 ] && [ -f "$CACHE" ]; then
  # Rebuild if the cache is older than 24h (mtime more than a day ago).
  if [ -z "$(find "$CACHE" -mtime +1 -print 2>/dev/null)" ]; then
    cache_stale=0
  fi
fi

if [ "$cache_stale" -eq 1 ]; then
  # Ensure each project is in zoxide.
  for path in $(find "$PROJECTS" -maxdepth 1 -mindepth 1 -type d -o -type l); do
    if [[ -L "$path" ]] && [[ ! -e "$path" ]]; then
      continue
    fi
    if [[ $(zoxide query -l -s "$path" | wc -c) -eq 0 ]]; then
      zoxide add "$path"
    fi
  done
  mkdir -p "$(dirname "$CACHE")"
  zoxide query -l "$PROJECTS/" | sed "s|$PROJECTS/||" >"$CACHE"
fi

filter_params=""
if [ -n "${1:-}" ]; then
  filter_params="-q $1"
fi
repo_path=$(fzf $filter_params --select-1 <"$CACHE")
[ -z "$repo_path" ] && exit 0

session=$(basename "$repo_path")
dir="$PROJECTS/$repo_path"
zoxide add "$dir"

build_workspace() {
  # If a workspace with this label already exists, just focus it.
  local existing
  existing=$(herdr workspace list \
    | jq -r --arg l "$session" '.result.workspaces[] | select(.label == $l) | .workspace_id' \
    | head -n1)
  if [ -n "$existing" ]; then
    herdr workspace focus "$existing" >/dev/null
    return
  fi

  # Create the workspace; its root pane becomes the editor tab.
  local ws_json ws_id editor_tab editor_pane git_pane files_pane
  ws_json=$(herdr workspace create --cwd "$dir" --label "$session" --focus)
  ws_id=$(echo "$ws_json" | jq -r '.result.workspace.workspace_id')
  editor_tab=$(echo "$ws_json" | jq -r '.result.tab.tab_id')
  editor_pane=$(echo "$ws_json" | jq -r '.result.root_pane.pane_id')
  herdr tab rename "$editor_tab" editor >/dev/null
  herdr pane run "$editor_pane" "${EDITOR:-vi}" >/dev/null

  # shell tab
  herdr tab create --workspace "$ws_id" --cwd "$dir" --label shell --no-focus >/dev/null

  # git tab -> lazygit
  git_pane=$(herdr tab create --workspace "$ws_id" --cwd "$dir" --label git --no-focus \
    | jq -r '.result.root_pane.pane_id')
  herdr pane run "$git_pane" "lazygit" >/dev/null

  # files tab -> yazi
  files_pane=$(herdr tab create --workspace "$ws_id" --cwd "$dir" --label files --no-focus \
    | jq -r '.result.root_pane.pane_id')
  herdr pane run "$files_pane" "yazi" >/dev/null

  # Focus the workspace (leaves the editor tab active).
  herdr workspace focus "$ws_id" >/dev/null
}

build_workspace
