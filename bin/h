#!/usr/bin/env bash
set -euo pipefail

# Herdr project workspace manager (herdr port of `t`).
# Picks a project under $PROJECTS with fzf and opens a Herdr workspace for it,
# with one tab each for editor, shell, git (lazygit), and files (yazi).

PROJECTS="$HOME/code"

# Ensure each project is in zoxide.
for path in $(find "$PROJECTS" -maxdepth 1 -mindepth 1 -type d -o -type l); do
  if [[ -L "$path" ]] && [[ ! -e "$path" ]]; then
    continue
  fi
  if [[ $(zoxide query -l -s "$path" | wc -c) -eq 0 ]]; then
    zoxide add "$path"
  fi
done

filter_params=""
if [ -n "${1:-}" ]; then
  filter_params="-q $1"
fi
repo_path=$(zoxide query -l "$PROJECTS/" | sed "s|$PROJECTS/||" | fzf $filter_params --select-1)
[ -z "$repo_path" ] && exit 0

session=$(basename "$repo_path")
dir="$PROJECTS/$repo_path"
zoxide add "$dir"

# If a workspace with this label already exists, just focus it.
existing=$(herdr workspace list \
  | jq -r --arg l "$session" '.result.workspaces[] | select(.label == $l) | .workspace_id' \
  | head -n1)
if [ -n "$existing" ]; then
  herdr workspace focus "$existing" >/dev/null
  exit 0
fi

# Create the workspace; its root pane becomes the editor tab.
ws_json=$(herdr workspace create --cwd "$dir" --label "$session" --focus)
ws_id=$(echo "$ws_json" | jq -r '.result.workspace.workspace_id')
editor_pane=$(echo "$ws_json" | jq -r '.result.root_pane.pane_id')
herdr pane run "$editor_pane" "${EDITOR:-vi}"

# shell tab
herdr tab create --workspace "$ws_id" --cwd "$dir" --label shell --no-focus >/dev/null

# git tab -> lazygit
git_pane=$(herdr tab create --workspace "$ws_id" --cwd "$dir" --label git --no-focus \
  | jq -r '.result.root_pane.pane_id')
herdr pane run "$git_pane" "lazygit"

# files tab -> yazi
files_pane=$(herdr tab create --workspace "$ws_id" --cwd "$dir" --label files --no-focus \
  | jq -r '.result.root_pane.pane_id')
herdr pane run "$files_pane" "yazi"

# Focus the workspace (leaves the editor tab active).
herdr workspace focus "$ws_id" >/dev/null
