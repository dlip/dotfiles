#!/usr/bin/env bash
# Project switcher (tmux). Picks a repo from ~/code/projects.txt with fzf and
# either attaches to its existing tmux session or creates a fresh one with
# editor / shell / lazygit / nnn windows.
set -euo pipefail

# Open project
filter_params=""
if [ -n "${1:-}" ]; then
	filter_params="-q $1"
fi
repo_path=$(cat ~/code/projects.txt | fzf $filter_params --select-1)
session=$(basename $repo_path)
if [ -n "$repo_path" ]; then
	cd ~/$repo_path
	if tmux has-session -t $session 2>/dev/null; then
		tmux attach-session -t "$session"
	else
		tmux new-session -d -s $session -n editor
		window=1
		tmux send-keys -t $session:$window "$EDITOR" Enter
		window=2
		tmux new-window -t $session:$window -n 'shell'
		window=3
		tmux new-window -t $session:$window -n 'git'
		tmux send-keys -t $session:$window "lazygit" Enter
		window=4
		tmux new-window -t $session:$window -n 'files'
		tmux send-keys -t $session:$window "nnn" Enter
		window=1
		tmux select-window -t $session:$window
		tmux attach-session -t "$session"
	fi
fi
