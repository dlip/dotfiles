#!/usr/bin/env bash
# Flatten a .mokuro JSON file into plain text — one OCR'd block per line —
# by concatenating every line of every block on every page.
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <file.mokuro>" >&2
  exit 1
fi

jq -r '
  .pages[]
  | .blocks[]
  | .lines
  | join("")
' "$1"
