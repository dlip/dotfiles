#!/usr/bin/env bash
# Tmux variant of `work`: starts a "work" tmux session and immediately opens
# the `nixconfig` project in it via `p`, waiting for that command to signal
# `project_opened`.
set -euo pipefail

session="work"
tmux new-session -d -s $session
tmux send-keys -t $session 'p nixconfig' C-m
tmux wait project_opened
