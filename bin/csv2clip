#!/usr/bin/env bash
# csv2clip — parse a CSV and copy it to the clipboard as tab-separated values
# so it can be pasted straight into a spreadsheet UI (Excel, Google Sheets,
# Numbers, etc.), with each field landing in its own cell.
#
# Reads from a file argument or stdin, parses the CSV properly (handling quoted
# fields, embedded commas, and newlines), converts rows to tab-separated lines,
# and writes the result to the clipboard via `cpy`.
#
# Usage:
#     csv2clip data.csv      # copy data.csv
#     cat data.csv | csv2clip  # copy from stdin
set -euo pipefail

python3 -c '
import csv, sys

reader = csv.reader(sys.stdin)
out = sys.stdout
for row in reader:
    # Strip embedded tabs/newlines from cells so the TSV layout stays intact.
    cells = [c.replace("\t", " ").replace("\r", " ").replace("\n", " ") for c in row]
    out.write("\t".join(cells) + "\n")
' < "${1:-/dev/stdin}" | cpy
