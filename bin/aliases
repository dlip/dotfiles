# Shell aliases sourced from ~/.zshrc — short single-letter aliases for
# frequently used commands (editors, file managers, git, fzf job picker, etc.)
# plus a couple of helpers for renaming, ripgrep, lazygit, zellij, and forcing
# Wayland for VS Code.
alias c='clear'
alias g='git'
alias h='hx'
alias j='fg %$(jobs | fzf | sed '\''s/^\[\([0-9]*\)\].*/\1/'\'')'
alias n='nnn'
alias ren='qmv -f do'
alias s='rg --files-with-matches'
alias v='nvim'
alias x='xplr'
alias ls='lsd'
alias lg='lazygit'
# alias find='fd';
alias grc='git reset $(git merge-base HEAD origin/main)'
alias rt='zellij action rename-tab'
alias zj='zellij'
alias code='code --enable-features=UseOzonePlatform --ozone-platform=wayland'
