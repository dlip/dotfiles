#!/usr/bin/env bash
# Strip cue numbers, timestamps and blank lines from a .srt subtitle file,
# leaving just the dialogue text on stdout. Usage: srt2txt <file.srt>
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <file.srt>" >&2
  exit 1
fi

sed \
  -e '/^[0-9]\+$/d' \
  -e '/^[0-9][0-9]:[0-9][0-9]:[0-9][0-9],[0-9][0-9][0-9] -->/d' \
  -e '/^$/d' \
  "$1"
