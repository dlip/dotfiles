#!/usr/bin/env bash
# Print the SHA at which a feature branch diverged from `main` (or any
# branch passed in $1) by intersecting first-parent revlists. Useful as the
# base ref for `git rebase -i`.
set -euo pipefail

FROM="${1:-HEAD}"
TO="${1:-main}"
BRANCH_POINT=$(diff -u <(git rev-list --first-parent "$TO") <(git rev-list --first-parent "$FROM") | sed -ne \"s/^ //p\" | head -1)
echo $BRANCH_POINT
