#!/usr/bin/env bash
# Apply the home-manager configuration for the current host. The flake target
# is read from $NIXCONFIG. Existing files are backed up with a timestamped
# `.nixbackup` extension so home-manager's switch never refuses to clobber.
set -euo pipefail

export HOME_MANAGER_BACKUP_EXT=$(date +"%Y%m%d%H%M%S").nixbackup
nix run home-manager/master -- switch --flake .#$NIXCONFIG "$@"
