#!/usr/bin/env bash
# Picks a random animated wallpaper from ~/sync/wallpapers/animated and plays
# it fullscreen via mpv+xwinwrap on every connected X11 monitor. Kills any
# existing xwinwrap processes first so re-running this swaps wallpapers.

_screen() {
    xwinwrap -ov -g $1 -- mpv --fullscreen\
        --on-all-workspaces \
        --no-stop-screensaver \
        --loop-file --no-audio --no-osc --no-osd-bar -wid WID --quiet \
        "$2" --background="$3" --video-zoom="$4" &
}

killall xwinwrap

sleep 0.5
FILE="$HOME/sync/wallpapers/animated/$(ls $HOME/sync/wallpapers/animated/ | shuf -n 1)"
for i in $( xrandr -q | grep ' connected' | grep -oP '\d+x\d+\+\d+\+\d+')
do
    _screen $i "$FILE" "${2:-#000000}" "${3:-0}"
done