#!/usr/bin/env bash
# Niri compositor user-session bootstrap: launches my preferred set of apps
# (terminal, file manager, Telegram, Chrome, Obsidian, Discord) on the
# `terminal` workspace, plus background helpers like cliphist, fcitx5,
# udiskie and xwayland-satellite.

if [[ $(whoami) == 'dane' ]]; then
  niri msg action focus-workspace terminal &
  kitty -e t dotfiles &
  wl-paste --watch cliphist store &
  thunar &
  Telegram &
  waytron google-chrome-stable &
  waytron obsidian &
  waytron discord &
fi
# hypridle &

udiskie --tray &
fcitx5 -d -r &
fcitx5-remote -r &
xwayland-satellite &
