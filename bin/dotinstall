#!/usr/bin/env bash
# Bootstrap this dotfiles repo into a fresh home directory: clones the repo
# into ~ via a temporary directory, backs up any conflicting files into
# ~/.dotbackup, then resets the worktree to match the repo and pulls
# submodules.
set -euo pipefail

if [ -d "$HOME/.git" ]; then
  echo "Error: ~/.git directory already exists. Please remove it first with 'rm -rf ~/.git'"
  exit 1
fi

TMP_DIR=$(mktemp -d)
cd ~
git clone https://github.com/dlip/dotfiles.git $TMP_DIR
mv $TMP_DIR/.git .
rm -rf $TMP_DIR
echo "*** Backing up any existing files to ~/.dotbackup, restore with 'rsync -a ~/.dotbackup ~' ***"
mkdir -p .dotbackup
git status
git diff-index --diff-filter=dr --name-only HEAD | xargs -I {} rsync -R {} .dotbackup/
git reset --hard
git submodule update --init
